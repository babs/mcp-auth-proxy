# =============================================================================
# mcp-auth-proxy — Docker Compose environment template
# Copy to .env and fill in the blanks (run scripts/generate-secrets.sh first).
# =============================================================================

# ---------------------------------------------------------------------------
# OIDC Identity Provider (Keycloak in the compose stack)
# ---------------------------------------------------------------------------

# Internal Docker DNS hostname for back-channel (token exchange, JWKS fetch).
# The browser is redirected to keycloak:8080 during the OAuth flow, so you
# must also add "127.0.0.1 keycloak" to your /etc/hosts on the host machine.
# See manifests/README.md → Prerequisites.
OIDC_ISSUER_URL=http://keycloak:8080/realms/mcp-demo

# Client ID registered in the realm-export.json
OIDC_CLIENT_ID=mcp-auth-proxy

# DEMO ONLY — matches realm-export.json. Rotate before any real use.
OIDC_CLIENT_SECRET=changeme-DEMO-ONLY

# ---------------------------------------------------------------------------
# Proxy public URL & upstream MCP server
# ---------------------------------------------------------------------------

# Public URL the proxy advertises to MCP clients.
# Must match the port mapping in compose.yaml (8080:8080).
PROXY_BASE_URL=http://localhost:8080

# Origin of the upstream MCP server (scheme + host + port, no path).
# The proxy forwards the client request path verbatim, so the upstream
# must serve MCP at /mcp (same path the proxy exposes).
UPSTREAM_MCP_URL=http://mcp-server:8000

# ---------------------------------------------------------------------------
# Token signing secret (AES-GCM)
# ---------------------------------------------------------------------------

# CRITICAL: Must be >= 32 bytes, byte-identical across ALL replica pods.
# A mismatched secret breaks every cross-pod token validation silently.
# Generate with:  bash scripts/generate-secrets.sh
# WARNING: Do NOT commit a real secret to source control.
TOKEN_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Redis (replay protection)
# ---------------------------------------------------------------------------

# Enables single-use authorization codes and refresh-token reuse detection.
# Redis is required by default (REDIS_REQUIRED=true). Set REDIS_REQUIRED=false
# only for dev/single-replica environments that accept the replay trade-off.
REDIS_URL=redis://redis:6379/0
REDIS_REQUIRED=true
REDIS_KEY_PREFIX=mcp-auth-proxy:

# ---------------------------------------------------------------------------
# Optional / tuning
# ---------------------------------------------------------------------------

LISTEN_ADDR=:8080
METRICS_ADDR=:9090
LOG_LEVEL=info

# Claim in the id_token that carries user group memberships (default: groups)
GROUPS_CLAIM=groups

# Comma-separated allowlist. Empty = allow all authenticated users.
ALLOWED_GROUPS=

# Bulk revocation: reject tokens with iat before this RFC3339 timestamp.
# Update + redeploy to invalidate all live tokens (access + refresh).
REVOKE_BEFORE=

# Set false to allow clients that omit PKCE (Cursor, MCP Inspector, ChatGPT).
PKCE_REQUIRED=true

# Graceful shutdown deadline. Raise if you have long-lived SSE streams.
# Must match terminationGracePeriodSeconds in K8s Deployment.
SHUTDOWN_TIMEOUT=120s

# Per-IP rate limiting on /register, /authorize, /callback, /token.
RATE_LIMIT_ENABLED=true

# Set true to accept /authorize without a client-supplied state parameter
# (legacy Cursor / MCP Inspector compatibility).
COMPAT_ALLOW_STATELESS=false
